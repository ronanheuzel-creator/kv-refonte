# Configuration WordPress — copier ce fichier en `.env` et remplir les valeurs.
# Ne JAMAIS commit le fichier .env (déjà dans .gitignore).

# URL de base du site WordPress (sans slash final)
WP_BASE_URL=https://stagging.kotonavision.com

# Nom d'utilisateur WordPress (le "Nom d'utilisateur" non modifiable dans wp-admin/profile.php)
WP_USER=ton-username

# Mot de passe d'application WordPress (généré dans wp-admin/profile.php → "Mots de passe d'application")
# Format: xxxx yyyy zzzz aaaa bbbb cccc (garder les espaces tels quels)
WP_APP_PASSWORD=xxxx yyyy zzzz aaaa bbbb cccc
